{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./out",
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
,     "proxy.txt", "app/dashboard/lead-table"  ],
  "exclude": [
    "node_modules"
  ]
}